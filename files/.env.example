# Zkopíruj tento soubor jako .env a vyplň svůj skutečný API klíč.
# Soubor .env je v .gitignore - NIKDY se necommituje do GitHubu.
# Klíč zdarma získáš na https://openweathermap.org/api (tier "Free")

OPENWEATHER_API_KEY=tvuj_api_klic_zde

# Lokace - výchozí Litoměřice, uprav podle potřeby
CITY_NAME=Litomerice
LATITUDE=50.5341
LONGITUDE=14.1310

# Volitelné
DB_PATH=data/weather.db
LOG_LEVEL=INFO

# --- Pro api_server.py a ai_assistant.py (volitelné rozšíření) ---

# Anthropic API klíč pro generování AI shrnutí (https://console.anthropic.com)
ANTHROPIC_API_KEY=tvuj_anthropic_klic_zde

# Vlastní API klíče pro autorizaci REST rozhraní - vymysli si libovolné
# náhodné řetězce (např. pomocí `python3 -c "import secrets; print(secrets.token_hex(16))"`)
API_KEY_READ=vymysli_si_nahodny_klic_pro_cteni
API_KEY_ADMIN=vymysli_si_nahodny_klic_pro_admina

# --- Telegram notifikace (notify.py) - volitelné, bez nich se notifikace jen přeskočí ---
# Token získáš od @BotFather v Telegramu, chat_id přes https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=tvuj_telegram_bot_token
TELEGRAM_CHAT_ID=tvoje_telegram_chat_id
